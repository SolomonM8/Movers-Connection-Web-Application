SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
# DATABASE_URL=postgres://user:password@host:port/dbname

# Uploaded media (profile pictures, banners, board post photos) needs Cloudinary in
# production — get these three values from your Cloudinary dashboard after signing
# up free at cloudinary.com. Leave unset for local dev (uploads fall back to the
# local media/ folder).
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret

# Push notifications (mobile app) need a Firebase service account key to send
# via FCM. Get this from Firebase Console -> Project Settings -> Service
# Accounts -> Generate new private key, then paste the entire JSON file
# contents as a single-line value here. Leave unset to skip sending pushes
# (in-app notifications still work as normal).
# FIREBASE_CREDENTIALS_JSON={"type": "service_account", ...}

# Google / Facebook sign-in buttons on the login page only appear once their
# matching pair of client id/secret is set. Leave either pair unset to skip
# that provider entirely -- nothing else changes.
# Google Cloud Console -> APIs & Services -> Credentials -> OAuth client ID
# (Web application) -> Authorized redirect URI:
#   https://themoversconnection.com/social-auth/google/login/callback/
#   http://127.0.0.1:8000/social-auth/google/login/callback/  (local testing)
# GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret
#
# Meta for Developers -> your app -> Facebook Login -> Settings -> Valid OAuth
# Redirect URIs (Facebook requires HTTPS even for local testing -- use a
# tunnel like ngrok):
#   https://themoversconnection.com/social-auth/facebook/login/callback/
# FACEBOOK_OAUTH_CLIENT_ID=your-app-id
# FACEBOOK_OAUTH_CLIENT_SECRET=your-app-secret
